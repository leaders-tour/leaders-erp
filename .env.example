DATABASE_URL="mysql://root:root@localhost:3306/tour_itinerary"
API_PORT=4000
WEB_GRAPHQL_URL="http://localhost:4000/graphql"
VITE_GRAPHQL_URL="http://localhost:4000/graphql"
WEB_ORIGIN="http://localhost:5173"

AUTH_ACCESS_TOKEN_SECRET="change-me-access-secret"
AUTH_ACCESS_TOKEN_TTL_MINUTES=30
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_REFRESH_COOKIE_NAME="tour_refresh_token"
AUTH_BOOTSTRAP_ADMIN_NAME="ERP 관리자"
AUTH_BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
AUTH_BOOTSTRAP_ADMIN_PASSWORD="change-me-admin-password"

# LocationGuide image upload (API -> S3 direct upload)
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
S3_BUCKET="your-s3-bucket-name"
# Optional. Prefix for separating environments in same bucket (e.g. dev, prd)
S3_KEY_PREFIX="dev"
# Optional. If omitted, URL is https://<bucket>.s3.<region>.amazonaws.com/<key>
# S3_PUBLIC_BASE_URL="https://your-bucket.s3.ap-northeast-2.amazonaws.com"
S3_UPLOAD_TIMEOUT_MS=20000
