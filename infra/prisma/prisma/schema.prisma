generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VariantType {
  basic
  afternoon
  extend
  early
  earlyExtend
}

enum LocationTimeBlockProfile {
  DEFAULT
  FIRST_DAY
  FIRST_DAY_EARLY
}

enum SegmentScheduleVariant {
  basic
  early
  extend
  earlyExtend
}

enum MovementIntensity {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
  LEVEL_5
}

enum BlockType {
  STAY
  TRANSFER
}

enum OverrideTargetType {
  DayPlan
  TimeBlock
  Activity
}

enum MealOption {
  CAMP_MEAL
  LOCAL_RESTAURANT
  PORK_PARTY
  HORHOG
  SHASHLIK
  SHABU_SHABU
}

enum FacilityAvailability {
  YES
  LIMITED
  NO
}

enum PricingPolicyStatus {
  ACTIVE
  INACTIVE
}

enum PricingLineCode {
  BASE
  BASE_PERCENT
  BASE_UPLIFT_5PLUS_5PCT
  BASE_UPLIFT_5PLUS_10PCT
  LONG_DISTANCE
  NIGHT_TRAIN
  PICKUP_DROP
  EXTRA_LODGING
  LODGING_SELECTION
  CONDITIONAL
  HIACE
  EARLY
  EXTEND
  MANUAL_ADJUSTMENT
}

enum PricingCalcType {
  AMOUNT
  PERCENT_OF_LINE
}

enum PricingQuantitySource {
  ONE
  HEADCOUNT
  TOTAL_DAYS
  LONG_DISTANCE_SEGMENT_COUNT
  NIGHT_TRAIN_BLOCK_COUNT
  SUM_EXTRA_LODGING_COUNTS
}

enum PricingLineSourceType {
  RULE
  MANUAL
}

enum PricingChargeScope {
  TEAM
  PER_PERSON
}

enum PricingPersonMode {
  SINGLE
  PER_DAY
  PER_NIGHT
}

enum PricingLodgingSelectionLevel {
  LV1
  LV2
  LV4
}

enum PricingPriceItemPreset {
  BASE
  BASE_PERCENT
  LONG_DISTANCE
  NIGHT_TRAIN
  EXTRA_LODGING
  LODGING_SELECTION
  PICKUP_DROP
  CONDITIONAL
  MANUAL_PRESET
}

enum PricingRuleType {
  BASE
  PERCENT_UPLIFT
  CONDITIONAL_ADDON
  LONG_DISTANCE
  AUTO_EXCEPTION
  MANUAL
}

enum PricingTimeBand {
  DAWN
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

enum PricingExternalTransferMode {
  ANY
  PICKUP_ONLY
  DROP_ONLY
  BOTH
}

/// 견적·빌더 표시용: 계산 단가/수량과 별개로 오른쪽 산식을 만든다.
enum PricingDisplayBasis {
  TEAM_DIV_PERSON
  PER_NIGHT
  PER_DAY
  PER_PERSON_SINGLE
  PERCENT
  CUSTOM
}

enum SecurityDepositMode {
  NONE
  PER_PERSON
  PER_TEAM
}

enum DealStage {
  CONSULTING
  CONTRACTING
  CONTRACT_CONFIRMED
  MONGOL_ASSIGNING
  MONGOL_ASSIGNED
  ON_HOLD
  BEFORE_DEPARTURE_10D
  BEFORE_DEPARTURE_3D
  TRIP_COMPLETED
}

enum DealTodoStatus {
  TODO
  DOING
  DONE
}

enum EmployeeRole {
  ADMIN
  STAFF
}

enum CafeSourceType {
  NAVER_CAFE_BOARD
}

enum CafeLeadStatus {
  DISCOVERED
  FETCHED
  PARSED
  DRAFTED
  APPROVED
  SENT
  SKIPPED
  FAILED
}

enum OutreachReviewStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

enum OutboundChannel {
  EMAIL
}

enum OutboundDeliveryStatus {
  QUEUED
  SENT
  FAILED
  BOUNCED
}

enum PlaceType {
  AIRPORT
  OZ_HOUSE
  ULAANBAATAR
  CUSTOM
}

model Employee {
  id           String              @id @default(uuid(7))
  name         String
  email        String              @unique
  passwordHash String
  role         EmployeeRole        @default(STAFF)
  isActive     Boolean             @default(true)

  ownedUsers    User[]                @relation("UserOwnerEmployee")
  refreshTokens EmployeeRefreshToken[]
  reviewedOutreachDrafts OutreachDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, role])
}

model EmployeeRefreshToken {
  id          String    @id @default(uuid(7))
  employeeId  String
  tokenHash   String    @unique
  userAgent   String?
  expiresAt   DateTime
  revokedAt   DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, expiresAt])
  @@index([employeeId, revokedAt])
}

model CafeSource {
  id         String         @id @default(uuid(7))
  sourceType CafeSourceType
  cafeId     String
  menuId     String
  boardName  String
  boardUrl   String         @db.Text
  isActive   Boolean        @default(true)

  leads CafeLead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceType, cafeId, menuId])
  @@index([isActive, sourceType])
}

model CafeLead {
  id              String         @id @default(uuid(7))
  cafeSourceId    String
  articleId       String         @unique
  articleUrl      String         @db.Text
  title           String
  authorNickname  String?
  postedAtRaw     String?
  postedAt        DateTime?
  views           Int?
  commentCount    Int?
  rawHtml         String?        @db.LongText
  rawText         String?        @db.LongText
  rawMetadataJson Json?
  parsedNeedsJson Json?
  contactEmail    String?
  contactPhone    String?
  leadScore       Int?
  status          CafeLeadStatus @default(DISCOVERED)
  failReason      String?        @db.Text
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())

  cafeSource     CafeSource       @relation(fields: [cafeSourceId], references: [id], onDelete: Cascade)
  outreachDrafts OutreachDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cafeSourceId, status, createdAt])
  @@index([status, leadScore])
  @@index([contactEmail])
  @@index([postedAt])
}

model OutreachDraft {
  id            String               @id @default(uuid(7))
  cafeLeadId    String
  version       Int
  subject       String
  previewText   String?
  bodyText      String               @db.LongText
  bodyHtml      String               @db.LongText
  promptVersion String
  modelName     String
  qualityScore  Int?
  reviewStatus  OutreachReviewStatus @default(PENDING)
  reviewerId    String?
  reviewedAt    DateTime?

  cafeLead          CafeLead           @relation(fields: [cafeLeadId], references: [id], onDelete: Cascade)
  reviewer          Employee?          @relation(fields: [reviewerId], references: [id], onDelete: SetNull)
  outboundMessages  OutboundMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cafeLeadId, version])
  @@index([reviewStatus, updatedAt])
  @@index([reviewerId])
}

model OutboundMessage {
  id                String                 @id @default(uuid(7))
  draftId           String
  channel           OutboundChannel        @default(EMAIL)
  toEmail           String
  deliveryStatus    OutboundDeliveryStatus @default(QUEUED)
  provider          String?
  providerMessageId String?
  failReason        String?                @db.Text
  sentAt            DateTime?

  draft OutreachDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([draftId, createdAt])
  @@index([deliveryStatus, createdAt])
  @@index([toEmail, createdAt])
}

model ContactSuppression {
  id       String  @id @default(uuid(7))
  email    String  @unique
  reason   String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, email])
}

model User {
  id              String    @id @default(uuid(7))
  name            String
  email           String?   @unique
  dealStage       DealStage @default(CONSULTING)
  dealStageOrder  Int       @default(0)
  ownerEmployeeId String?

  ownerEmployee Employee?      @relation("UserOwnerEmployee", fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  plans         Plan[]
  notes         UserNote[]
  dealTodos     UserDealTodo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealStage, dealStageOrder])
  @@index([ownerEmployeeId])
}

model UserNote {
  id        String @id @default(uuid(7))
  userId    String
  content   String @db.Text
  createdBy String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model DealTodoTemplate {
  id          String    @id @default(uuid(7))
  stage       DealStage
  title       String
  description String?   @db.Text
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)

  userDealTodos UserDealTodo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage, isActive, sortOrder])
}

model UserDealTodo {
  id          String         @id @default(uuid(7))
  userId      String
  stage       DealStage
  templateId  String?
  title       String
  description String?        @db.Text
  status      DealTodoStatus @default(TODO)
  completedAt DateTime?

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template  DealTodoTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, stage, templateId])
  @@index([userId, status, createdAt])
  @@index([userId, stage, status])
}

model Region {
  id          String     @id @default(uuid(7))
  name        String
  description String?

  defaultRegionSetId String?  @unique
  defaultRegionSet   RegionSet? @relation("RegionDefaultRegionSet", fields: [defaultRegionSetId], references: [id], onDelete: Restrict)

  locations Location[]
  segments  Segment[]
  overnightStays OvernightStay[]
  overnightStayConnections OvernightStayConnection[]
  regionSetItems RegionSetItem[]
  regionLodgings RegionLodging[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RegionSet {
  id        String    @id @default(uuid(7))
  signature String    @unique
  name      String
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  items            RegionSetItem[]
  defaultForRegion Region?         @relation("RegionDefaultRegionSet")
  plans            Plan[]
  planVersions     PlanVersion[]
  planTemplates    PlanTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, deletedAt])
}

model RegionSetItem {
  id          String @id @default(uuid(7))
  regionSetId String
  regionId    String
  sortOrder   Int

  regionSet RegionSet @relation(fields: [regionSetId], references: [id], onDelete: Cascade)
  region    Region    @relation(fields: [regionId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([regionSetId, regionId])
  @@index([regionSetId])
  @@index([regionId])
}

model Location {
  id                 String  @id @default(uuid(7))
  regionId           String
  regionName         String
  name               Json
  defaultLodgingType String
  isFirstDayEligible Boolean @default(false)
  isLastDayEligible  Boolean @default(false)
  latitude           Float?
  longitude          Float?
  currentVersionId   String?

  region       Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromSegments Segment[] @relation("FromLocation")
  toSegments   Segment[] @relation("ToLocation")
  overnightStays OvernightStay[]
  overnightStaysAsStart OvernightStay[] @relation("OvernightStayStartLocation")
  overnightStaysAsEnd OvernightStay[] @relation("OvernightStayEndLocation")
  overnightStayDaysAsDisplay OvernightStayDay[] @relation("OvernightStayDayDisplayLocation")
  toOvernightStayConnections OvernightStayConnection[] @relation("OvernightStayConnectionToLocation")
  versions     LocationVersion[] @relation("LocationVersions")
  currentVersion LocationVersion? @relation("CurrentLocationVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  guide        LocationGuide?
  lodgings     Lodging[]
  mealSets     MealSet[]
  timeBlocks   TimeBlock[]
  planStops    PlanStop[]
  planTemplateStops PlanTemplateStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([currentVersionId])
}

model LocationGuide {
  id          String  @id @default(uuid(7))
  title       String
  description String  @db.Text
  imageUrls   Json
  locationId  String? @unique

  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

model LocationVersion {
  id                     String @id @default(uuid(7))
  locationId             String
  versionNumber          Int
  label                  String
  changeNote             String?
  locationNameSnapshot   Json
  regionNameSnapshot     String
  defaultLodgingType     String
  firstDayAverageDistanceKm  Float?
  firstDayAverageTravelHours Float?
  firstDayMovementIntensity  MovementIntensity?

  location      Location         @relation("LocationVersions", fields: [locationId], references: [id], onDelete: Cascade)
  currentForLocations Location[] @relation("CurrentLocationVersion")
  lodgings      Lodging[]
  mealSets      MealSet[]
  timeBlocks    TimeBlock[]
  planStops     PlanStop[]
  planTemplateStops PlanTemplateStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, versionNumber])
  @@index([locationId])
}

model OvernightStay {
  id              String    @id @default(uuid(7))
  regionId        String
  locationId      String
  blockType      BlockType  @default(STAY)
  startLocationId String
  endLocationId   String
  name            String
  isNightTrain    Boolean   @default(false)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)

  region        Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  location      Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  startLocation Location  @relation("OvernightStayStartLocation", fields: [startLocationId], references: [id], onDelete: Cascade)
  endLocation   Location  @relation("OvernightStayEndLocation", fields: [endLocationId], references: [id], onDelete: Cascade)
  days          OvernightStayDay[]
  outgoingConnections OvernightStayConnection[]
  planStopsAsMultiDayBlock PlanStop[] @relation("PlanStopMultiDayBlock")
  planTemplateStopsAsMultiDayBlock PlanTemplateStop[] @relation("PlanTemplateStopMultiDayBlock")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([locationId])
  @@index([startLocationId])
  @@index([endLocationId])
}

model OvernightStayDay {
  id                 String  @id @default(uuid(7))
  overnightStayId    String
  dayOrder           Int
  displayLocationId  String
  averageDistanceKm  Float
  averageTravelHours Float
  movementIntensity  MovementIntensity
  timeCellText       String  @db.Text
  scheduleCellText   String  @db.Text
  lodgingCellText    String  @db.Text
  mealCellText       String  @db.Text

  overnightStay   OvernightStay @relation(fields: [overnightStayId], references: [id], onDelete: Cascade)
  displayLocation Location     @relation("OvernightStayDayDisplayLocation", fields: [displayLocationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([overnightStayId])
  @@index([displayLocationId])
  @@unique([overnightStayId, dayOrder])
}

model OvernightStayConnection {
  id                 String @id @default(uuid(7))
  regionId           String
  regionName         String
  fromOvernightStayId String
  toLocationId       String
  defaultVersionId   String?
  averageDistanceKm  Float
  averageTravelHours Float
  movementIntensity  MovementIntensity
  isLongDistance     Boolean @default(false)

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromOvernightStay OvernightStay @relation(fields: [fromOvernightStayId], references: [id], onDelete: Cascade)
  toLocation Location @relation("OvernightStayConnectionToLocation", fields: [toLocationId], references: [id])
  defaultVersion OvernightStayConnectionVersion? @relation("OvernightStayConnectionDefaultVersion", fields: [defaultVersionId], references: [id], onDelete: SetNull)
  versions OvernightStayConnectionVersion[] @relation("OvernightStayConnectionVersions")
  scheduleTimeBlocks OvernightStayConnectionTimeBlock[]
  planStopsAsMultiDayBlockConnection PlanStop[] @relation("PlanStopMultiDayBlockConnection")
  planTemplateStopsAsMultiDayBlockConnection PlanTemplateStop[] @relation("PlanTemplateStopMultiDayBlockConnection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([defaultVersionId])
  @@unique([fromOvernightStayId, toLocationId])
}

model OvernightStayConnectionVersion {
  id                         String @id @default(uuid(7))
  overnightStayConnectionId  String
  name                       String
  averageDistanceKm          Float
  averageTravelHours         Float
  movementIntensity          MovementIntensity
  isLongDistance             Boolean @default(false)
  sortOrder                  Int
  isDefault                  Boolean @default(false)

  overnightStayConnection OvernightStayConnection @relation("OvernightStayConnectionVersions", fields: [overnightStayConnectionId], references: [id], onDelete: Cascade)
  defaultForConnections OvernightStayConnection[] @relation("OvernightStayConnectionDefaultVersion")
  scheduleTimeBlocks OvernightStayConnectionVersionTimeBlock[]
  planStopsAsMultiDayBlockConnectionVersion PlanStop[] @relation("PlanStopMultiDayBlockConnectionVersion")
  planTemplateStopsAsMultiDayBlockConnectionVersion PlanTemplateStop[] @relation("PlanTemplateStopMultiDayBlockConnectionVersion")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([overnightStayConnectionId])
  @@unique([overnightStayConnectionId, sortOrder])
}

model OvernightStayConnectionVersionTimeBlock {
  id                               String @id @default(uuid(7))
  overnightStayConnectionVersionId String
  variant                          SegmentScheduleVariant @default(basic)
  startTime                        String
  label                            String
  orderIndex                       Int

  overnightStayConnectionVersion OvernightStayConnectionVersion @relation(fields: [overnightStayConnectionVersionId], references: [id], onDelete: Cascade)
  activities OvernightStayConnectionVersionActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([overnightStayConnectionVersionId])
  @@unique([overnightStayConnectionVersionId, variant, orderIndex])
}

model OvernightStayConnectionVersionActivity {
  id                                        String @id @default(uuid(7))
  overnightStayConnectionVersionTimeBlockId String
  description                               String
  orderIndex                                Int
  isOptional                                Boolean @default(false)
  conditionNote                             String?

  overnightStayConnectionVersionTimeBlock OvernightStayConnectionVersionTimeBlock @relation(fields: [overnightStayConnectionVersionTimeBlockId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([overnightStayConnectionVersionTimeBlockId])
  @@unique([overnightStayConnectionVersionTimeBlockId, orderIndex])
}

model Segment {
  id                 String @id @default(uuid(7))
  regionId           String
  regionName         String
  fromLocationId     String
  toLocationId       String
  defaultVersionId   String?
  averageDistanceKm  Float
  averageTravelHours Float
  movementIntensity  MovementIntensity
  isLongDistance     Boolean @default(false)

  region       Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromLocation Location @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location @relation("ToLocation", fields: [toLocationId], references: [id])
  defaultVersion SegmentVersion? @relation("SegmentDefaultVersion", fields: [defaultVersionId], references: [id], onDelete: SetNull)
  versions     SegmentVersion[] @relation("SegmentVersions")
  scheduleTimeBlocks SegmentTimeBlock[]
  planStops PlanStop[]
  planTemplateStops PlanTemplateStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([defaultVersionId])
  @@unique([fromLocationId, toLocationId])
}

model SegmentVersion {
  id                 String @id @default(uuid(7))
  segmentId          String
  name               String
  averageDistanceKm  Float
  averageTravelHours Float
  movementIntensity  MovementIntensity
  isLongDistance     Boolean @default(false)
  startDate          DateTime?
  endDate            DateTime?
  flightOutTimeBand  PricingTimeBand?
  overrideLodgingIsUnspecified Boolean?
  overrideLodgingName          String?
  overrideHasElectricity       FacilityAvailability?
  overrideHasShower            FacilityAvailability?
  overrideHasInternet          FacilityAvailability?
  overrideBreakfast            MealOption?
  overrideLunch                MealOption?
  overrideDinner               MealOption?
  sortOrder          Int
  isDefault          Boolean @default(false)

  segment         Segment @relation("SegmentVersions", fields: [segmentId], references: [id], onDelete: Cascade)
  defaultForSegments Segment[] @relation("SegmentDefaultVersion")
  scheduleTimeBlocks SegmentVersionTimeBlock[]
  planStops       PlanStop[]
  planTemplateStops PlanTemplateStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([segmentId])
  @@unique([segmentId, sortOrder])
}

model SegmentVersionTimeBlock {
  id               String @id @default(uuid(7))
  segmentVersionId String
  variant          SegmentScheduleVariant @default(basic)
  startTime        String
  label            String
  orderIndex       Int

  segmentVersion SegmentVersion @relation(fields: [segmentVersionId], references: [id], onDelete: Cascade)
  activities     SegmentVersionActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([segmentVersionId])
  @@unique([segmentVersionId, variant, orderIndex])
}

model SegmentVersionActivity {
  id                        String  @id @default(uuid(7))
  segmentVersionTimeBlockId String
  description               String
  orderIndex                Int
  isOptional                Boolean @default(false)
  conditionNote             String?

  segmentVersionTimeBlock SegmentVersionTimeBlock @relation(fields: [segmentVersionTimeBlockId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([segmentVersionTimeBlockId])
  @@unique([segmentVersionTimeBlockId, orderIndex])
}

model Plan {
  id               String  @id @default(uuid(7))
  userId           String
  regionSetId      String
  title            String
  documentNumberBase String @unique
  currentVersionId String?

  user           User          @relation(fields: [userId], references: [id])
  regionSet      RegionSet     @relation(fields: [regionSetId], references: [id], onDelete: Restrict)
  versions       PlanVersion[] @relation("PlanVersions")
  currentVersion PlanVersion?  @relation("CurrentPlanVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([regionSetId])
  @@index([currentVersionId])
}

model PlanVersion {
  id              String  @id @default(uuid(7))
  planId          String
  regionSetId     String
  parentVersionId String?
  versionNumber   Int
  variantType     VariantType
  totalDays       Int
  changeNote      String?

  plan          Plan          @relation("PlanVersions", fields: [planId], references: [id], onDelete: Cascade)
  regionSet     RegionSet     @relation(fields: [regionSetId], references: [id], onDelete: Restrict)
  parentVersion PlanVersion?  @relation("PlanVersionParentChild", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions PlanVersion[] @relation("PlanVersionParentChild")
  planAsCurrent Plan[]        @relation("CurrentPlanVersion")
  meta          PlanVersionMeta?
  pricing       PlanVersionPricing?
  planStops     PlanStop[]
  planVersionEvents PlanVersionEvent[]
  overrides     Override[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, versionNumber])
  @@index([planId])
  @@index([regionSetId])
  @@index([parentVersionId])
}

model PlanVersionMeta {
  id                     String   @id @default(uuid(7))
  planVersionId          String   @unique
  leaderName             String
  documentNumber         String   @unique
  travelStartDate        DateTime
  travelEndDate          DateTime
  headcountTotal         Int
  headcountMale          Int
  headcountFemale        Int
  vehicleType            String
  flightInTime           String
  flightOutTime          String
  pickupDate             DateTime?
  pickupTime             String?
  dropDate               DateTime?
  dropTime               String?
  pickupDropNote         String?
  pickupPlaceType        PlaceType?
  pickupPlaceCustomText  String?
  dropPlaceType          PlaceType?
  dropPlaceCustomText    String?
  externalPickupDate     DateTime?
  externalPickupTime     String?
  externalPickupPlaceType       PlaceType?
  externalPickupPlaceCustomText String?
  externalDropDate       DateTime?
  externalDropTime       String?
  externalDropPlaceType        PlaceType?
  externalDropPlaceCustomText  String?
  externalPickupDropNote String?
  externalTransfers      Json?
  specialNote            String?  @db.Text
  includeRentalItems     Boolean  @default(true)
  rentalItemsText        String   @db.Text
  eventCodes             Json
  extraLodgings          Json
  lodgingSelections      Json
  remark                 String?  @db.Text

  planVersion      PlanVersion               @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  transportGroups  PlanVersionTransportGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travelStartDate])
}

model PlanVersionTransportGroup {
  id                String    @id @default(uuid(7))
  planVersionMetaId String
  orderIndex        Int
  teamName          String
  headcount         Int
