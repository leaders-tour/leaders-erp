generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VariantType {
  basic
  early
  afternoon
  extend
}

enum OverrideTargetType {
  DayPlan
  TimeBlock
  Activity
}

enum MealOption {
  CAMP_MEAL
  LOCAL_RESTAURANT
  PORK_PARTY
  HORHOG
  SHASHLIK
  SHABU_SHABU
}

enum FacilityAvailability {
  YES
  LIMITED
  NO
}

model Region {
  id          String     @id @default(uuid(7))
  name        String
  description String?

  locations Location[]
  segments  Segment[]
  plans     Plan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id                 String  @id @default(uuid(7))
  regionId           String
  regionName         String
  name               String
  defaultLodgingType String
  internalMovementDistance Int?
  latitude           Float?
  longitude          Float?

  region       Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromSegments Segment[] @relation("FromLocation")
  toSegments   Segment[] @relation("ToLocation")
  lodgings     Lodging[]
  mealSets     MealSet[]
  timeBlocks   TimeBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
}

model Segment {
  id                 String @id @default(uuid(7))
  regionId           String
  regionName         String
  fromLocationId     String
  toLocationId       String
  averageDistanceKm  Float
  averageTravelHours Float

  region       Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromLocation Location @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location @relation("ToLocation", fields: [toLocationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@unique([fromLocationId, toLocationId])
}

model Plan {
  id          String      @id @default(uuid(7))
  regionId    String
  variantType VariantType
  totalDays   Int

  region    Region     @relation(fields: [regionId], references: [id])
  planStops PlanStop[]
  overrides Override[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
}

model PlanStop {
  id                  String @id @default(uuid(7))
  planId              String
  dateCellText        String @db.Text
  destinationCellText String @db.Text
  timeCellText        String @db.Text
  scheduleCellText    String @db.Text
  lodgingCellText     String @db.Text
  mealCellText        String @db.Text

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
}

model Lodging {
  id                   String @id @default(uuid(7))
  locationId           String
  locationNameSnapshot String
  name                 String
  specialNotes         String?
  isUnspecified        Boolean @default(false)
  hasElectricity       FacilityAvailability @default(NO)
  hasShower            FacilityAvailability @default(NO)
  hasInternet          FacilityAvailability @default(NO)

  location Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

model MealSet {
  id                   String     @id @default(uuid(7))
  locationId           String
  locationNameSnapshot String
  setName              String
  breakfast            MealOption?
  lunch                MealOption?
  dinner               MealOption?

  location Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@unique([locationId, setName])
}

model TimeBlock {
  id         String @id @default(uuid(7))
  locationId String
  startTime  String
  label      String
  orderIndex Int

  location   Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@unique([locationId, orderIndex])
}

model Activity {
  id            String  @id @default(uuid(7))
  timeBlockId   String
  description   String
  orderIndex    Int
  isOptional    Boolean @default(false)
  conditionNote String?

  timeBlock TimeBlock @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([timeBlockId])
  @@unique([timeBlockId, orderIndex])
}

model Override {
  id         String             @id @default(uuid(7))
  planId     String
  targetType OverrideTargetType
  targetId   String
  fieldName  String
  value      String

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
}
