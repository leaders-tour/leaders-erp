generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VariantType {
  basic
  afternoon
  extend
  earlyNight
  earlyMorning
  earlyNightExtend
  earlyMorningExtend
}

enum OverrideTargetType {
  DayPlan
  TimeBlock
  Activity
}

enum MealOption {
  CAMP_MEAL
  LOCAL_RESTAURANT
  PORK_PARTY
  HORHOG
  SHASHLIK
  SHABU_SHABU
}

enum FacilityAvailability {
  YES
  LIMITED
  NO
}

enum PricingPolicyStatus {
  ACTIVE
  INACTIVE
}

enum PricingLineCode {
  BASE
  BASE_UPLIFT_5PLUS_5PCT
  BASE_UPLIFT_5PLUS_10PCT
  LONG_DISTANCE
  HIACE
  EXTRA_LODGING
  EARLY_NIGHT
  EARLY_MORNING
  EXTEND
  MANUAL_ADJUSTMENT
}

enum PricingCalcType {
  AMOUNT
  PERCENT_OF_LINE
}

enum PricingQuantitySource {
  ONE
  TOTAL_DAYS
  LONG_DISTANCE_SEGMENT_COUNT
  SUM_EXTRA_LODGING_COUNTS
}

enum PricingLineSourceType {
  RULE
  MANUAL
}

model User {
  id    String  @id @default(uuid(7))
  name  String
  email String? @unique

  plans Plan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id          String     @id @default(uuid(7))
  name        String
  description String?

  locations Location[]
  segments  Segment[]
  plans     Plan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id                 String  @id @default(uuid(7))
  regionId           String
  regionName         String
  name               String
  defaultLodgingType String
  latitude           Float?
  longitude          Float?
  currentVersionId   String?

  region       Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromSegments Segment[] @relation("FromLocation")
  toSegments   Segment[] @relation("ToLocation")
  versions     LocationVersion[] @relation("LocationVersions")
  currentVersion LocationVersion? @relation("CurrentLocationVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  guide        LocationGuide?
  lodgings     Lodging[]
  mealSets     MealSet[]
  timeBlocks   TimeBlock[]
  planStops    PlanStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([currentVersionId])
}

model LocationGuide {
  id          String  @id @default(uuid(7))
  title       String
  description String  @db.Text
  imageUrls   Json
  locationId  String? @unique

  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

model LocationVersion {
  id                     String @id @default(uuid(7))
  locationId             String
  versionNumber          Int
  label                  String
  changeNote             String?
  locationNameSnapshot   String
  regionNameSnapshot     String
  defaultLodgingType     String

  location      Location         @relation("LocationVersions", fields: [locationId], references: [id], onDelete: Cascade)
  currentForLocations Location[] @relation("CurrentLocationVersion")
  lodgings      Lodging[]
  mealSets      MealSet[]
  timeBlocks    TimeBlock[]
  planStops     PlanStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, versionNumber])
  @@index([locationId])
}

model Segment {
  id                 String @id @default(uuid(7))
  regionId           String
  regionName         String
  fromLocationId     String
  toLocationId       String
  averageDistanceKm  Float
  averageTravelHours Float
  isLongDistance     Boolean @default(false)

  region       Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromLocation Location @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location @relation("ToLocation", fields: [toLocationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@unique([fromLocationId, toLocationId])
}

model Plan {
  id               String  @id @default(uuid(7))
  userId           String
  regionId         String
  title            String
  currentVersionId String?

  user           User          @relation(fields: [userId], references: [id])
  region         Region        @relation(fields: [regionId], references: [id])
  versions       PlanVersion[] @relation("PlanVersions")
  currentVersion PlanVersion?  @relation("CurrentPlanVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([regionId])
  @@index([currentVersionId])
}

model PlanVersion {
  id              String  @id @default(uuid(7))
  planId          String
  parentVersionId String?
  versionNumber   Int
  variantType     VariantType
  totalDays       Int
  changeNote      String?

  plan          Plan          @relation("PlanVersions", fields: [planId], references: [id], onDelete: Cascade)
  parentVersion PlanVersion?  @relation("PlanVersionParentChild", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions PlanVersion[] @relation("PlanVersionParentChild")
  planAsCurrent Plan[]        @relation("CurrentPlanVersion")
  meta          PlanVersionMeta?
  pricing       PlanVersionPricing?
  planStops     PlanStop[]
  overrides     Override[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, versionNumber])
  @@index([planId])
  @@index([parentVersionId])
}

model PlanVersionMeta {
  id                     String   @id @default(uuid(7))
  planVersionId          String   @unique
  leaderName             String
  documentNumber         String   @unique
  travelStartDate        DateTime
  travelEndDate          DateTime
  headcountTotal         Int
  headcountMale          Int
  headcountFemale        Int
  vehicleType            String
  flightInTime           String
  flightOutTime          String
  pickupDropNote         String?
  externalPickupDropNote String?
  includeRentalItems     Boolean  @default(true)
  rentalItemsText        String   @db.Text
  eventCodes             Json
  extraLodgings          Json
  remark                 String?  @db.Text

  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travelStartDate])
}

model PricingPolicy {
  id            String              @id @default(uuid(7))
  code          String              @unique
  name          String
  status        PricingPolicyStatus @default(ACTIVE)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  priority      Int                 @default(0)

  rules               PricingRule[]
  planVersionPricings PlanVersionPricing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, effectiveFrom, effectiveTo])
  @@index([priority])
}

model PricingRule {
  id             String               @id @default(uuid(7))
  policyId       String
  lineCode       PricingLineCode
  calcType       PricingCalcType
  targetLineCode PricingLineCode?
  amountKrw      Int?
  percentBps     Int?
  quantitySource PricingQuantitySource
  headcountMin   Int?
  headcountMax   Int?
  dayMin         Int?
  dayMax         Int?
  vehicleType    String?
  variantTypes   Json?
  isEnabled      Boolean              @default(true)
  sortOrder      Int                  @default(0)

  policy                  PricingPolicy           @relation(fields: [policyId], references: [id], onDelete: Cascade)
  planVersionPricingLines PlanVersionPricingLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId, lineCode, isEnabled, sortOrder])
}

model PlanVersionPricing {
  id             String @id @default(uuid(7))
  planVersionId  String @unique
  policyId       String
  currencyCode   String @default("KRW")
  baseAmountKrw  Int
  addonAmountKrw Int
  totalAmountKrw Int
  depositAmountKrw Int
  balanceAmountKrw Int
  inputSnapshot  Json

  planVersion PlanVersion            @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  policy      PricingPolicy          @relation(fields: [policyId], references: [id])
  lines       PlanVersionPricingLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
}

model PlanVersionPricingLine {
  id                   String                @id @default(uuid(7))
  planVersionPricingId String
  lineCode             PricingLineCode
  sourceType           PricingLineSourceType
  ruleId               String?
  description          String?
  unitPriceKrw         Int?
  quantity             Int
  amountKrw            Int
  meta                 Json?

  planVersionPricing PlanVersionPricing @relation(fields: [planVersionPricingId], references: [id], onDelete: Cascade)
  rule               PricingRule?       @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([planVersionPricingId])
  @@index([ruleId])
}

model PlanStop {
  id                  String @id @default(uuid(7))
  planVersionId       String
  locationId          String?
  locationVersionId   String?
  dateCellText        String @db.Text
  destinationCellText String @db.Text
  timeCellText        String @db.Text
  scheduleCellText    String @db.Text
  lodgingCellText     String @db.Text
  mealCellText        String @db.Text

  planVersion     PlanVersion     @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  location        Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planVersionId])
  @@index([locationId])
  @@index([locationVersionId])
}

model Lodging {
  id                   String @id @default(uuid(7))
  locationId           String
  locationVersionId    String?
  locationNameSnapshot String
  name                 String
  specialNotes         String?
  isUnspecified        Boolean @default(false)
  hasElectricity       FacilityAvailability @default(NO)
  hasShower            FacilityAvailability @default(NO)
  hasInternet          FacilityAvailability @default(NO)

  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([locationVersionId])
}

model MealSet {
  id                   String     @id @default(uuid(7))
  locationId           String
  locationVersionId    String?
  locationNameSnapshot String
  setName              String
  breakfast            MealOption?
  lunch                MealOption?
  dinner               MealOption?

  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([locationVersionId])
  @@unique([locationVersionId, setName])
}

model TimeBlock {
  id         String @id @default(uuid(7))
  locationId String
  locationVersionId String?
  startTime  String
  label      String
  orderIndex Int

  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)
  activities      Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([locationVersionId])
  @@unique([locationVersionId, orderIndex])
}

model Activity {
  id            String  @id @default(uuid(7))
  timeBlockId   String
  description   String
  orderIndex    Int
  isOptional    Boolean @default(false)
  conditionNote String?

  timeBlock TimeBlock @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([timeBlockId])
  @@unique([timeBlockId, orderIndex])
}

model Override {
  id         String             @id @default(uuid(7))
  planVersionId String
  targetType OverrideTargetType
  targetId   String
  fieldName  String
  value      String

  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planVersionId])
}
