generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VariantType {
  basic
  afternoon
  extend
  earlyNight
  earlyMorning
  earlyNightExtend
  earlyMorningExtend
}

enum OverrideTargetType {
  DayPlan
  TimeBlock
  Activity
}

enum MealOption {
  CAMP_MEAL
  LOCAL_RESTAURANT
  PORK_PARTY
  HORHOG
  SHASHLIK
  SHABU_SHABU
}

enum FacilityAvailability {
  YES
  LIMITED
  NO
}

enum PricingPolicyStatus {
  ACTIVE
  INACTIVE
}

enum PricingLineCode {
  BASE
  BASE_UPLIFT_5PLUS_5PCT
  BASE_UPLIFT_5PLUS_10PCT
  LONG_DISTANCE
  HIACE
  EXTRA_LODGING
  EARLY_NIGHT
  EARLY_MORNING
  EXTEND
  MANUAL_ADJUSTMENT
}

enum PricingCalcType {
  AMOUNT
  PERCENT_OF_LINE
}

enum PricingQuantitySource {
  ONE
  TOTAL_DAYS
  LONG_DISTANCE_SEGMENT_COUNT
  SUM_EXTRA_LODGING_COUNTS
}

enum PricingLineSourceType {
  RULE
  MANUAL
}

enum SecurityDepositMode {
  NONE
  PER_PERSON
  PER_TEAM
}

enum DealStage {
  CONSULTING
  CONTRACTING
  CONTRACT_CONFIRMED
  MONGOL_ASSIGNING
  MONGOL_ASSIGNED
  ON_HOLD
  BEFORE_DEPARTURE_10D
  BEFORE_DEPARTURE_3D
  TRIP_COMPLETED
}

enum DealTodoStatus {
  TODO
  DOING
  DONE
}

enum EmployeeRole {
  ADMIN
  STAFF
}

enum CafeSourceType {
  NAVER_CAFE_BOARD
}

enum CafeLeadStatus {
  DISCOVERED
  FETCHED
  PARSED
  DRAFTED
  APPROVED
  SENT
  SKIPPED
  FAILED
}

enum OutreachReviewStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

enum OutboundChannel {
  EMAIL
}

enum OutboundDeliveryStatus {
  QUEUED
  SENT
  FAILED
  BOUNCED
}

enum PlaceType {
  AIRPORT
  OZ_HOUSE
  ULAANBAATAR
  CUSTOM
}

model Employee {
  id           String              @id @default(uuid(7))
  name         String
  email        String              @unique
  passwordHash String
  role         EmployeeRole        @default(STAFF)
  isActive     Boolean             @default(true)

  ownedUsers    User[]                @relation("UserOwnerEmployee")
  refreshTokens EmployeeRefreshToken[]
  reviewedOutreachDrafts OutreachDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, role])
}

model EmployeeRefreshToken {
  id          String    @id @default(uuid(7))
  employeeId  String
  tokenHash   String    @unique
  userAgent   String?
  expiresAt   DateTime
  revokedAt   DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, expiresAt])
  @@index([employeeId, revokedAt])
}

model CafeSource {
  id         String         @id @default(uuid(7))
  sourceType CafeSourceType
  cafeId     String
  menuId     String
  boardName  String
  boardUrl   String         @db.Text
  isActive   Boolean        @default(true)

  leads CafeLead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceType, cafeId, menuId])
  @@index([isActive, sourceType])
}

model CafeLead {
  id              String         @id @default(uuid(7))
  cafeSourceId    String
  articleId       String         @unique
  articleUrl      String         @db.Text
  title           String
  authorNickname  String?
  postedAtRaw     String?
  postedAt        DateTime?
  views           Int?
  commentCount    Int?
  rawHtml         String?        @db.LongText
  rawText         String?        @db.LongText
  rawMetadataJson Json?
  parsedNeedsJson Json?
  contactEmail    String?
  contactPhone    String?
  leadScore       Int?
  status          CafeLeadStatus @default(DISCOVERED)
  failReason      String?        @db.Text
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())

  cafeSource     CafeSource       @relation(fields: [cafeSourceId], references: [id], onDelete: Cascade)
  outreachDrafts OutreachDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cafeSourceId, status, createdAt])
  @@index([status, leadScore])
  @@index([contactEmail])
  @@index([postedAt])
}

model OutreachDraft {
  id            String               @id @default(uuid(7))
  cafeLeadId    String
  version       Int
  subject       String
  previewText   String?
  bodyText      String               @db.LongText
  bodyHtml      String               @db.LongText
  promptVersion String
  modelName     String
  qualityScore  Int?
  reviewStatus  OutreachReviewStatus @default(PENDING)
  reviewerId    String?
  reviewedAt    DateTime?

  cafeLead          CafeLead           @relation(fields: [cafeLeadId], references: [id], onDelete: Cascade)
  reviewer          Employee?          @relation(fields: [reviewerId], references: [id], onDelete: SetNull)
  outboundMessages  OutboundMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cafeLeadId, version])
  @@index([reviewStatus, updatedAt])
  @@index([reviewerId])
}

model OutboundMessage {
  id                String                 @id @default(uuid(7))
  draftId           String
  channel           OutboundChannel        @default(EMAIL)
  toEmail           String
  deliveryStatus    OutboundDeliveryStatus @default(QUEUED)
  provider          String?
  providerMessageId String?
  failReason        String?                @db.Text
  sentAt            DateTime?

  draft OutreachDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([draftId, createdAt])
  @@index([deliveryStatus, createdAt])
  @@index([toEmail, createdAt])
}

model ContactSuppression {
  id       String  @id @default(uuid(7))
  email    String  @unique
  reason   String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, email])
}

model User {
  id              String    @id @default(uuid(7))
  name            String
  email           String?   @unique
  dealStage       DealStage @default(CONSULTING)
  dealStageOrder  Int       @default(0)
  ownerEmployeeId String?

  ownerEmployee Employee?      @relation("UserOwnerEmployee", fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  plans         Plan[]
  notes         UserNote[]
  dealTodos     UserDealTodo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealStage, dealStageOrder])
  @@index([ownerEmployeeId])
}

model UserNote {
  id        String @id @default(uuid(7))
  userId    String
  content   String @db.Text
  createdBy String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model DealTodoTemplate {
  id          String    @id @default(uuid(7))
  stage       DealStage
  title       String
  description String?   @db.Text
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)

  userDealTodos UserDealTodo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage, isActive, sortOrder])
}

model UserDealTodo {
  id          String         @id @default(uuid(7))
  userId      String
  stage       DealStage
  templateId  String?
  title       String
  description String?        @db.Text
  status      DealTodoStatus @default(TODO)
  completedAt DateTime?

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template  DealTodoTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, stage, templateId])
  @@index([userId, status, createdAt])
  @@index([userId, stage, status])
}

model Region {
  id          String     @id @default(uuid(7))
  name        String
  description String?

  locations Location[]
  segments  Segment[]
  plans     Plan[]
  planTemplates PlanTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id                 String  @id @default(uuid(7))
  regionId           String
  regionName         String
  name               String
  defaultLodgingType String
  latitude           Float?
  longitude          Float?
  currentVersionId   String?

  region       Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromSegments Segment[] @relation("FromLocation")
  toSegments   Segment[] @relation("ToLocation")
  versions     LocationVersion[] @relation("LocationVersions")
  currentVersion LocationVersion? @relation("CurrentLocationVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  guide        LocationGuide?
  lodgings     Lodging[]
  mealSets     MealSet[]
  timeBlocks   TimeBlock[]
  planStops    PlanStop[]
  planTemplateStops PlanTemplateStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([currentVersionId])
}

model LocationGuide {
  id          String  @id @default(uuid(7))
  title       String
  description String  @db.Text
  imageUrls   Json
  locationId  String? @unique

  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

model LocationVersion {
  id                     String @id @default(uuid(7))
  locationId             String
  versionNumber          Int
  label                  String
  changeNote             String?
  locationNameSnapshot   String
  regionNameSnapshot     String
  defaultLodgingType     String

  location      Location         @relation("LocationVersions", fields: [locationId], references: [id], onDelete: Cascade)
  currentForLocations Location[] @relation("CurrentLocationVersion")
  lodgings      Lodging[]
  mealSets      MealSet[]
  timeBlocks    TimeBlock[]
  planStops     PlanStop[]
  planTemplateStops PlanTemplateStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, versionNumber])
  @@index([locationId])
}

model Segment {
  id                 String @id @default(uuid(7))
  regionId           String
  regionName         String
  fromLocationId     String
  toLocationId       String
  averageDistanceKm  Float
  averageTravelHours Float
  isLongDistance     Boolean @default(false)

  region       Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromLocation Location @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location @relation("ToLocation", fields: [toLocationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@unique([fromLocationId, toLocationId])
}

model Plan {
  id               String  @id @default(uuid(7))
  userId           String
  regionId         String
  title            String
  documentNumberBase String @unique
  currentVersionId String?

  user           User          @relation(fields: [userId], references: [id])
  region         Region        @relation(fields: [regionId], references: [id])
  versions       PlanVersion[] @relation("PlanVersions")
  currentVersion PlanVersion?  @relation("CurrentPlanVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([regionId])
  @@index([currentVersionId])
}

model PlanVersion {
  id              String  @id @default(uuid(7))
  planId          String
  parentVersionId String?
  versionNumber   Int
  variantType     VariantType
  totalDays       Int
  changeNote      String?

  plan          Plan          @relation("PlanVersions", fields: [planId], references: [id], onDelete: Cascade)
  parentVersion PlanVersion?  @relation("PlanVersionParentChild", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions PlanVersion[] @relation("PlanVersionParentChild")
  planAsCurrent Plan[]        @relation("CurrentPlanVersion")
  meta          PlanVersionMeta?
  pricing       PlanVersionPricing?
  planStops     PlanStop[]
  planVersionEvents PlanVersionEvent[]
  overrides     Override[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, versionNumber])
  @@index([planId])
  @@index([parentVersionId])
}

model PlanVersionMeta {
  id                     String   @id @default(uuid(7))
  planVersionId          String   @unique
  leaderName             String
  documentNumber         String   @unique
  travelStartDate        DateTime
  travelEndDate          DateTime
  headcountTotal         Int
  headcountMale          Int
  headcountFemale        Int
  vehicleType            String
  flightInTime           String
  flightOutTime          String
  pickupDate             DateTime?
  pickupTime             String?
  dropDate               DateTime?
  dropTime               String?
  pickupDropNote         String?
  pickupPlaceType        PlaceType?
  pickupPlaceCustomText  String?
  dropPlaceType          PlaceType?
  dropPlaceCustomText    String?
  externalPickupDate     DateTime?
  externalPickupTime     String?
  externalPickupPlaceType       PlaceType?
  externalPickupPlaceCustomText String?
  externalDropDate       DateTime?
  externalDropTime       String?
  externalDropPlaceType        PlaceType?
  externalDropPlaceCustomText  String?
  externalPickupDropNote String?
  specialNote            String?  @db.Text
  includeRentalItems     Boolean  @default(true)
  rentalItemsText        String   @db.Text
  eventCodes             Json
  extraLodgings          Json
  remark                 String?  @db.Text

  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travelStartDate])
}

model Event {
  id                 String @id @default(uuid(7))
  name               String
  isActive           Boolean @default(true)
  securityDepositKrw Int @default(0)
  sortOrder          Int @default(0)

  planVersionEvents PlanVersionEvent[]
  securityDepositPlanVersionPricings PlanVersionPricing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model PlanVersionEvent {
  id            String @id @default(uuid(7))
  planVersionId String
  eventId       String

  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@unique([planVersionId, eventId])
  @@index([planVersionId])
  @@index([eventId])
}

model PricingPolicy {
  id            String              @id @default(uuid(7))
  code          String              @unique
  name          String
  status        PricingPolicyStatus @default(ACTIVE)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  priority      Int                 @default(0)

  rules               PricingRule[]
  planVersionPricings PlanVersionPricing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, effectiveFrom, effectiveTo])
  @@index([priority])
}

model PricingRule {
  id             String               @id @default(uuid(7))
  policyId       String
  lineCode       PricingLineCode
  calcType       PricingCalcType
  targetLineCode PricingLineCode?
  amountKrw      Int?
  percentBps     Int?
  quantitySource PricingQuantitySource
  headcountMin   Int?
  headcountMax   Int?
  dayMin         Int?
  dayMax         Int?
  vehicleType    String?
  variantTypes   Json?
  isEnabled      Boolean              @default(true)
  sortOrder      Int                  @default(0)

  policy                  PricingPolicy           @relation(fields: [policyId], references: [id], onDelete: Cascade)
  planVersionPricingLines PlanVersionPricingLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId, lineCode, isEnabled, sortOrder])
}

model PlanVersionPricing {
  id             String @id @default(uuid(7))
  planVersionId  String @unique
  policyId       String
  currencyCode   String @default("KRW")
  baseAmountKrw  Int
  addonAmountKrw Int
  totalAmountKrw Int
  depositAmountKrw Int
  balanceAmountKrw Int
  securityDepositAmountKrw    Int                @default(0)
  securityDepositUnitPriceKrw Int                @default(0)
  securityDepositQuantity     Int                @default(0)
  securityDepositMode         SecurityDepositMode @default(NONE)
  securityDepositEventId      String?
  inputSnapshot  Json

  planVersion          PlanVersion            @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  policy               PricingPolicy          @relation(fields: [policyId], references: [id])
  securityDepositEvent Event?                 @relation(fields: [securityDepositEventId], references: [id], onDelete: SetNull)
  lines                PlanVersionPricingLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@index([securityDepositEventId])
}

model PlanVersionPricingLine {
  id                   String                @id @default(uuid(7))
  planVersionPricingId String
  lineCode             PricingLineCode
  sourceType           PricingLineSourceType
  ruleId               String?
  description          String?
  unitPriceKrw         Int?
  quantity             Int
  amountKrw            Int
  meta                 Json?

  planVersionPricing PlanVersionPricing @relation(fields: [planVersionPricingId], references: [id], onDelete: Cascade)
  rule               PricingRule?       @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([planVersionPricingId])
  @@index([ruleId])
}

model PlanTemplate {
  id          String  @id @default(uuid(7))
  name        String
  description String? @db.Text
  regionId    String
  totalDays   Int
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  planStops PlanTemplateStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId, totalDays, isActive, sortOrder])
}

model PlanTemplateStop {
  id                String @id @default(uuid(7))
  planTemplateId    String
  dayIndex          Int
  locationId        String?
  locationVersionId String?
  dateCellText      String @db.Text
  destinationCellText String @db.Text
  timeCellText      String @db.Text
  scheduleCellText  String @db.Text
  lodgingCellText   String @db.Text
  mealCellText      String @db.Text

  planTemplate    PlanTemplate    @relation(fields: [planTemplateId], references: [id], onDelete: Cascade)
  location        Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planTemplateId, dayIndex])
  @@index([planTemplateId])
  @@index([locationId])
  @@index([locationVersionId])
}

model PlanStop {
  id                  String @id @default(uuid(7))
  planVersionId       String
  locationId          String?
  locationVersionId   String?
  dateCellText        String @db.Text
  destinationCellText String @db.Text
  timeCellText        String @db.Text
  scheduleCellText    String @db.Text
  lodgingCellText     String @db.Text
  mealCellText        String @db.Text

  planVersion     PlanVersion     @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  location        Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planVersionId])
  @@index([locationId])
  @@index([locationVersionId])
}

model Lodging {
  id                   String @id @default(uuid(7))
  locationId           String
  locationVersionId    String?
  locationNameSnapshot String
  name                 String
  specialNotes         String?
  isUnspecified        Boolean @default(false)
  hasElectricity       FacilityAvailability @default(NO)
  hasShower            FacilityAvailability @default(NO)
  hasInternet          FacilityAvailability @default(NO)

  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([locationVersionId])
}

model MealSet {
  id                   String     @id @default(uuid(7))
  locationId           String
  locationVersionId    String?
  locationNameSnapshot String
  setName              String
  breakfast            MealOption?
  lunch                MealOption?
  dinner               MealOption?

  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([locationVersionId])
  @@unique([locationVersionId, setName])
}

model TimeBlock {
  id         String @id @default(uuid(7))
  locationId String
  locationVersionId String?
  startTime  String
  label      String
  orderIndex Int

  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationVersion LocationVersion? @relation(fields: [locationVersionId], references: [id], onDelete: SetNull)
  activities      Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([locationVersionId])
  @@unique([locationVersionId, orderIndex])
}

model Activity {
  id            String  @id @default(uuid(7))
  timeBlockId   String
  description   String
  orderIndex    Int
  isOptional    Boolean @default(false)
  conditionNote String?

  timeBlock TimeBlock @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([timeBlockId])
  @@unique([timeBlockId, orderIndex])
}

model Override {
  id         String             @id @default(uuid(7))
  planVersionId String
  targetType OverrideTargetType
  targetId   String
  fieldName  String
  value      String

  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planVersionId])
}
