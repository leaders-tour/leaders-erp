{
  "name": "tour-itinerary-erp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "start": "pnpm --parallel --filter @tour/api --filter @tour/web dev",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "codegen": "pnpm --filter @tour/web codegen"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^5.6.2"
  }
}
